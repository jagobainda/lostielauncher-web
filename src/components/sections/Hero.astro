---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";
import { GITHUB_URL, INSTALLER_URL } from "../../lib/launcher";
import type { LandingData } from "../../lib/types";

interface Props {
    hero: LandingData["hero"];
    version: string | null;
}

const { hero, version } = Astro.props;
---

<section id="download" class="relative overflow-hidden">
    <div
        class="pointer-events-none absolute top-0 left-1/2 -z-10 h-[32rem] w-[52rem] -translate-x-1/2 -translate-y-1/3 rounded-full bg-(--accent) opacity-15 blur-3xl"
        aria-hidden="true"
    >
    </div>

    <div class="mx-auto max-w-4xl px-4 pt-24 pb-20 text-center sm:px-6 sm:pt-28" data-hero>
        <img
            src="/imgs/favicon/favicon.png"
            alt=""
            class="mx-auto size-24 drop-shadow-lg"
            width="96"
            height="96"
            data-fade
        />

        <h1 class="mt-6 text-5xl font-bold tracking-tight sm:text-6xl" data-fade>LostieLauncher</h1>
        <p class="mt-4 text-xl font-medium text-(--accent) sm:text-2xl" data-fade>{hero.tagline}</p>
        <p class="mx-auto mt-4 max-w-2xl text-(--text-dim)" data-fade>{hero.subtitle}</p>

        {
            version && (
                <p
                    class="mt-6 inline-flex items-center gap-1.5 rounded-full bg-(--overlay-subtle) px-3 py-1 text-xs text-(--text-dim)"
                    data-fade
                >
                    <Icon name="bi:tag" class="size-3" />
                    {hero.versionPrefix} {version.replace(/^v/, "")}
                </p>
            )
        }

        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row" data-fade>
            <Button href={INSTALLER_URL} variant="primary" class="w-full text-lg sm:w-auto">
                <Icon name="bi:download" class="size-5" />
                {hero.downloadCta}
            </Button>
            <Button
                href={GITHUB_URL}
                variant="secondary"
                target="_blank"
                rel="noopener noreferrer"
                class="w-full sm:w-auto"
            >
                <Icon name="bi:github" class="size-5" />
                {hero.githubCta}
            </Button>
        </div>
        <p class="mt-4 text-sm text-(--text-dim)" data-fade>{hero.downloadNote}</p>

        <ul class="mx-auto mt-14 grid max-w-3xl grid-cols-2 gap-x-6 gap-y-8 md:grid-cols-4" data-fade>
            {
                hero.features.map(feature => (
                    <li class="flex flex-col items-center gap-2.5">
                        <span class="flex size-11 items-center justify-center rounded-lg bg-(--overlay-subtle) text-(--accent)">
                            <Icon name={feature.icon} class="size-5" />
                        </span>
                        <span class="text-sm text-(--text-dim)">{feature.text}</span>
                    </li>
                ))
            }
        </ul>
    </div>
</section>

<script>
    import { staggerInOnScroll } from "../../scripts/animations";

    staggerInOnScroll("[data-hero]", "[data-fade]");
</script>
